# Copy this file to .env and fill in your values.
# The .env file is loaded as a fallback when environment variables are not set.
# Real environment variables always take precedence over .env values.
#
# NEVER commit a populated .env file to source control.

# ── AWS Credentials ────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2

# ── SQS ───────────────────────────────────────────────────────────────────────
SQS_QUEUE_URL=

# ── Seerr (Overseerr / Jellyseerr) ────────────────────────────────────────────
SEERR_BASE_URL=
SEERR_API_KEY=

# ── Optional tuning ───────────────────────────────────────────────────────────
# SQS_MAX_MESSAGES=10
# SQS_VISIBILITY_TIMEOUT=30
# SQS_WAIT_TIME_SECONDS=20
# SQS_POLLING_INTERVAL_MS=500
# LOG_LEVEL=info
# HEALTH_PORT=8080

# ── Pushover notifications ──────────────────────────────────────────────────────
# If set, errors send a Pushover notification.
# PUSHOVER_TOKEN is your app token; PUSHOVER_URL is the webhook URL
# from https://pushover.net (format: https://api.pushover.net/1/webhooks/<key>.json)
PUSHOVER_TOKEN=
PUSHOVER_URL=

# ── OpenTelemetry ─────────────────────────────────────────────────────────────
# Set OTEL_ENABLED=true and point to your collector to enable tracing.
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=otel-collector:4317
# OTEL_SERVICE_NAME=seerr-service
